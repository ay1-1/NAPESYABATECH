rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Student Profiles
    match /students/{studentId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isOwner(request.resource.data.uid) && isValidId(studentId);
      allow update: if isSignedIn() && isOwner(resource.data.uid) && 
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['fullName', 'department', 'level', 'isPaid']);
    }

    // Engineering Resources
    match /resources/{resourceId} {
      allow read: if isSignedIn();
      allow create, update, delete: if false; // Reserved for Admin logic or Cloud Functions
    }

    // News & Announcements
    match /announcements/{newsId} {
      allow read: if true; // Publicly readable
      allow write: if false; // System only
    }
  }
}
